# k3s-esxi .env — 填好这个文件后告诉 Dan 路径
# 复制这个文件，填入你的实际值

# ── ESXi 主机 ──────────────────────────────────────────────────────────────────
ESXI_HOST=192.168.1.10
ESXI_USER=root
ESXI_PASS=your-esxi-password

# ── Datastore 名称（ESXi Web UI → Storage 里看）──────────────────────────────
ESXI_DATASTORE_SSD=datastore1          # Master VM 放这里（SSD 优先）
ESXI_DATASTORE_HDD=datastore2          # Worker VM 放这里（HDD）

# ── Ubuntu ISO（上传到 datastore 的 ISO 文件名）────────────────────────────────
UBUNTU_ISO_DATASTORE=datastore1
UBUNTU_ISO_NAME=ubuntu-24.04-live-server-amd64.iso

# ── 网络（ESXi Web UI → Networking → Port Groups 里看名字）───────────────────
VM_NETWORK=VM Network
GATEWAY=192.168.1.1
DNS=1.1.1.1

# ── VM 静态 IP（选你家网段里空闲的 IP）────────────────────────────────────────
MASTER_IP=192.168.1.101
WORKER1_IP=192.168.1.102
WORKER2_IP=192.168.1.103
SUBNET_PREFIX=24                       # /24 = 255.255.255.0

# ── VM 登录用户和 SSH key ─────────────────────────────────────────────────────
VM_USER=ubuntu
VM_SSH_KEY_PUB=~/.ssh/id_rsa.pub       # 你的 SSH public key 路径

# ── k3s 版本（留空 = 自动用最新稳定版）────────────────────────────────────────
K3S_VERSION=
K3S_TOKEN=                             # 安装 master 后自动填入，先留空

# ── Longhorn 版本（留空 = 自动用最新）────────────────────────────────────────
LONGHORN_VERSION=
LONGHORN_REPLICA_COUNT=2
